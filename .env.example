# ── Secrets (required) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack — choose one mode:
#   Threaded (preferred): one thread reply per paper, reactions work per-paper
GRIP_SLACK_BOT_TOKEN=xoxb-your-bot-token-here
GRIP_SLACK_CHANNEL_ID=C01234ABCDE
#   Webhook fallback: single post, no per-paper reactions
GRIP_SLACK_WEBHOOK=https://hooks.slack.com/services/your/webhook/url

# ── Configuration (required) ────────────────────────────────────────────────────────
GRIP_DATA_DIR=src/grip/data

# ── Sources ───────────────────────────────────────────────────────────────────
# Comma-separated list of search terms
GRIP_SEARCH_TERMS=machine learning,deep learning

# NCBI API key (optional) — raises PubMed E-utilities rate limit from 3 → 10 req/s
# Get one free at https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=your_ncbi_api_key_here

# How many days back to look for papers
GRIP_DAYS_LOOKBACK=1

# Maximum papers to fetch per source
GRIP_MAX_FETCH=30

# ── Scoring ───────────────────────────────────────────────────────────────────
# Number of top papers to include in the digest
GRIP_TOP_N=5

# Claude model used for scoring papers
GRIP_SCORING_MODEL=claude-haiku-4-5-20251001

# Claude model used for updating the interest profile
GRIP_UPDATE_MODEL=claude-sonnet-4-6

# ── Feedback ──────────────────────────────────────────────────────────────────
# Number of days of feedback to consider when updating the profile
GRIP_FEEDBACK_DAYS=7

# Minimum number of feedback entries required before updating the profile
GRIP_MIN_FEEDBACK=5

# ── Paths ─────────────────────────────────────────────────────────────────────
# Directory for storing interest profile and feedback logs (defaults to package data dir)
# GRIP_DATA_DIR=/path/to/your/data/dir
